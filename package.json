{
  "name": "lonewriter",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.lonewriter.app",
    "productName": "LoneWriter",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/main.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/pwa-512x512.png",
      "artifactName": "LoneWriter Setup v1.0.exe"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "description": "",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tiptap/pm": "3.20.6",
    "@tiptap/react": "3.20.6",
    "@tiptap/starter-kit": "3.20.6",
    "dexie": "4.4.1",
    "file-saver": "^2.0.5",
    "html-to-docx": "^1.8.0",
    "lodash": "4.17.23",
    "lucide-react": "1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.4"
  }
}
